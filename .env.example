# -----------------------------------------------------------------------------
# MONOREPO ENVIRONMENT VARIABLES (Template)
# -----------------------------------------------------------------------------
# WARNING: NEVER commit the actual `.env` file to version control.
# Create a local `.env` copy and fill in the secure values.
# 
# Security checks applied:
# 1. No hardcoded secrets in source files.
# 2. Strict prefix boundaries (`NEXT_PUBLIC_`) explicitly state what can touch the client.
# 3. Connection strings stored in environment state only.

# --- Database (PostgreSQL via Docker/Railway) ---
# Used by Prisma in `packages/database`
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=srmall_dev
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"

# --- Next.js Web App (apps/web) ---
# Only expose variables prefixed with NEXT_PUBLIC_ to the browser.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Authentication & Secrets ---
# Keep strictly on the server (Route Handlers/SSR)
SESSION_SECRET="super-secret-session-key-change-me"
OTP_SERVICE_API_KEY="your-sms-provider-api-key"
