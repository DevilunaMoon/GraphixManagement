// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  phone       String?
  password      String?
  authProvider  String   @default("LOCAL")
  role        String   @default("CUSTOMER")
  image       String?
  gender      String?
  dateOfBirth String?
  status        String   @default("Active")
  suspendedUntil DateTime?
  resetToken    String?
  resetTokenExpiry DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reviews     Review[]
  purchases   Purchase[]
  repairRequests RepairRequest[]
  cartItems   CartItem[]
}

model Device {
  id          String   @id @default(cuid())
  name        String
  price       Float
  cost        Float    @default(0)
  stock       Int
  sold        Int      @default(0)
  specs       String?
  image       String?
  images      String[] @default([])
  downpaymentImage String?
  asLowAs     String?
  warranty    String?
  downpayment String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reviews     Review[]
  purchases   Purchase[]
  variations  DeviceVariation[]
  cartItems   CartItem[]

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model DeviceVariation {
  id        String   @id @default(cuid())
  type      String   
  name      String   
  price     Float
  cost      Float    @default(0)
  stock     Int
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}


model RepairRequest {
  id          String   @id @default(cuid())
  deviceName  String
  ownerName   String
  progress    String
  cause       String?
  technician  String?
  repairCost  String?
  image       String?
  proofImage  String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model TechnicianFeedback {
  id             String   @id @default(cuid())
  customerName   String
  technicianName String?
  feedbackText   String
  sentiment      String   @default("Positive")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  name      String?
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  devices   Device[]
}

model Policy {
  id        String   @id @default(cuid())
  type      String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  amount     Float    @default(0)
  quantity   Int      @default(1)
  variations String?
  createdAt  DateTime @default(now())
}

model CartItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  quantity   Int      @default(1)
  variations String?  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
